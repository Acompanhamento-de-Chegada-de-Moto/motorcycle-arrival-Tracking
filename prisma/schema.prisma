// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @unique()
  password String

  @@map("user")
}

model MotorcycleArrival {
  id          String   @id @default(uuid())
  chassi      String   @unique()
  modelo      String
  dataChegada DateTime
  criadoEm    DateTime

  @@map("motorcycle_arrival")
}
